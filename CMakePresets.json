{
  "version": 6,
  "configurePresets": [
    {
      "name": "default",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_COMPILE_WARNING_AS_ERROR": false
      }
    },
    {
      "name": "msvc",
      "inherits": "default"
    }
  ],
  "buildPresets": [
    {
      "name": "msvc-debug",
      "configurePreset": "msvc",
      "configuration": "Debug"
    },
    {
      "name": "msvc-release",
      "configurePreset": "msvc",
      "configuration": "Release"
    },
    {
      "name": "msvc-relwithdebinfo",
      "configurePreset": "msvc",
      "configuration": "RelWithDebInfo"
    }
  ],
  "testPresets": [
    {
      "name": "msvc-debug",
      "configurePreset": "msvc",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true,
        "verbosity": "verbose"
      },
      "execution": {
        "noTestsAction": "error",
        "scheduleRandom": true,
        "stopOnFailure": false,
        "timeout": 180,
        "jobs": 0
      }
    },
    {
      "name": "msvc-release",
      "configurePreset": "msvc",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true,
        "verbosity": "verbose"
      },
      "execution": {
        "noTestsAction": "error",
        "scheduleRandom": true,
        "stopOnFailure": false,
        "timeout": 180,
        "jobs": 0
      }
    },
    {
      "name": "msvc-relwithdebinfo",
      "configurePreset": "msvc",
      "configuration": "RelWithDebInfo",
      "output": {
        "outputOnFailure": true,
        "verbosity": "verbose"
      },
      "execution": {
        "noTestsAction": "error",
        "scheduleRandom": true,
        "stopOnFailure": false,
        "timeout": 180,
        "jobs": 0
      }
    }
  ],
  "workflowPresets": [
    {
      "name": "msvc-debug",
      "steps": [
        { "type": "configure", "name": "msvc" },
        { "type": "build", "name": "msvc-debug" },
        { "type": "test", "name": "msvc-debug" }
      ]
    },
    {
      "name": "msvc-release",
      "steps": [
        { "type": "configure", "name": "msvc" },
        { "type": "build", "name": "msvc-release" },
        { "type": "test", "name": "msvc-release" }
      ]
    },
    {
      "name": "msvc-relwithdebinfo",
      "steps": [
        { "type": "configure", "name": "msvc" },
        { "type": "build", "name": "msvc-relwithdebinfo" },
        { "type": "test", "name": "msvc-relwithdebinfo" }
      ]
    }
  ]
}
