{
  "version": 6,

"configurePresets": [
{
  "name": "default",
  "binaryDir": "${sourceDir}/build",
  "cacheVariables": {
    "CMAKE_COMPILE_WARNING_AS_ERROR": false
  }
},
{
  "name": "mingw-w64",
  "inherits": "default",
    "environment": {
      "MW_MINGW64_LOC": "C:\\mingw81",
      "BAR": "some-other-value"
    }
  }
],
"buildPresets": [
  {
    "name": "default",
    "configurePreset": "default"
  },
  {
    "name": "mingw-w64",
    "configurePreset": "mingw-w64"
  }
],
"testPresets": [
{
  "name": "default",
  "configurePreset": "default",
  "output": {
    "outputOnFailure": true,
    "verbosity": "verbose"
  },
  "execution": {
    "noTestsAction": "error",
    "scheduleRandom": true,
    "stopOnFailure": false,
    "timeout": 180,
    "jobs": 0
  }
},
{
  "name": "mingw-w64", "inherits": "default",
  "configurePreset": "mingw-w64"
}
],
"workflowPresets": [
  {
    "name": "default",
    "steps": [
      {
        "type": "configure",
        "name": "default"
      },
      {
        "type": "build",
        "name": "default"
      },
      {
        "type": "test",
        "name": "default"
      }
    ]
  },
  {
    "name": "mingw-w64",
    "steps": [
      {
        "type": "configure",
        "name": "mingw-w64"
      },
      {
        "type": "build",
        "name": "mingw-w64"
      },
      {
        "type": "test",
        "name": "mingw-w64"
      }
    ]
  }
]
}
